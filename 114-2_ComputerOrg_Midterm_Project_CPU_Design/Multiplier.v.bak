`timescale 1ns/1ns
module Multiplier( clk, reset, dataA, dataB, Signal, dataOut, busy );
    input         clk;
    input         reset;
    input  [31:0] dataA;
    input  [31:0] dataB;
    input  [5:0]  Signal;
    output [63:0] dataOut;
    output        busy;

    parameter MULTU = 6'd25;

    reg [63:0] multiplicand;
    reg [31:0] multiplier_reg;
    reg [63:0] product;
    reg [5:0]  counter;
    reg        busy;
    reg        started;

    always @( posedge clk or posedge reset ) begin
        if ( reset ) begin
            multiplicand   <= 64'b0;
            multiplier_reg <= 32'b0;
            product        <= 64'b0;
            counter        <= 6'd0;
            busy           <= 1'b0;
            started        <= 1'b0;
        end else begin
            if ( Signal == MULTU && started == 1'b0 ) begin
                multiplicand   <= { 32'b0, dataA };
                multiplier_reg <= dataB;
                product        <= 64'b0;
                counter        <= 6'd0;
                busy           <= 1'b1;
                started        <= 1'b1;
            end else if ( busy == 1'b1 ) begin
                if ( counter < 6'd32 ) begin
                    if ( multiplier_reg[0] == 1'b1 ) begin
                        product <= product + multiplicand;
                    end
                    multiplicand   <= multiplicand << 1;
                    multiplier_reg <= multiplier_reg >> 1;
                    counter        <= counter + 6'd1;
                end else begin
                    busy    <= 1'b0;
                    started <= 1'b0;
                end
            end else if ( Signal != MULTU ) begin
                started <= 1'b0;
            end
        end
    end

    assign dataOut = product;
endmodule